rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) && 
             data.keys().size() >= 3 &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.createdAt is timestamp;
    }

    // --- SavedResult Validation ---
    function isValidSavedResult(data) {
      return data.keys().hasAll(['userId', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['Life Path', 'Compatibility'] &&
             data.createdAt == request.time &&
             (data.get('note', '') is string && data.get('note', '').size() <= 1000);
    }

    // --- Matches ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']);
    }

    match /saved_results/{resultId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isOwner(existing().userId);
      allow create: if isSignedIn() && isValidSavedResult(incoming());
      allow update: if isOwner(existing().userId) && isValidSavedResult(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['note', 'name']);
      allow delete: if isOwner(existing().userId);
    }
  }
}
